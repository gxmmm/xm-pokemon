{
  "compilerOptions": {
    "target": "ES2021",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2021", "DOM", "DOM.Iterable"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": false,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "useDefineForClassFields": true,
    "jsx": "preserve",
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@pokemon-online/shared": ["packages/shared/src/index.ts"],
      "@pokemon-online/shared/*": ["packages/shared/src/*"],
      "@pokemon-online/config": ["packages/config/src/index.ts"],
      "@pokemon-online/config/*": ["packages/config/src/*"],
      "@pokemon-online/engine": ["packages/engine/src/index.ts"],
      "@pokemon-online/engine/*": ["packages/engine/src/*"]
    }
  },
  "include": ["packages/**/*", "apps/**/*"],
  "exclude": ["node_modules", "**/dist", "**/.wrangler"]
}
